# Firebase（クライアント）
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=xxx.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=xxx
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=xxx.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin（サーバー・check-user-id API 等）
FIREBASE_ADMIN_PROJECT_ID=xxx
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxx@xxx.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# 管理者UID（お知らせ作成ができるユーザー。NEXT_PUBLIC_ADMIN_UID と一致するユーザーのみ /admin/announcements でお知らせを追加可能）
# NEXT_PUBLIC_ADMIN_UID=your-firebase-auth-uid

# 記事本文のAI補正（いずれか一方で可。Gemini を優先し、失敗時は OpenAI にフォールバック）
# Gemini（無料枠あり）: https://aistudio.google.com/apikey で取得
# GEMINI_API_KEY=...
# OpenAI
# OPENAI_API_KEY=sk-...

# X（Twitter）OAuth 2.0（Xで新規登録で「設定して続ける」押下後にのみ Firebase ユーザーを作る場合に必要）
# X Developer Portal で OAuth 2.0 を有効にし、Callback URL に X_OAUTH_REDIRECT_URI を登録する
# X_OAUTH_CLIENT_ID=...
# X_OAUTH_CLIENT_SECRET=...
# X_OAUTH_REDIRECT_URI=https://yourdomain.com/api/auth/x-callback
# X_OAUTH_STATE_SECRET=任意の32文字以上の秘密文字列

# 本番のオリジン（コールバック後のリダイレクト先。未設定時はリクエストの origin を使用）
# NEXT_PUBLIC_APP_ORIGIN=https://yourdomain.com

# EC 検索リンク用アフィリエイト（任意）
# NEXT_PUBLIC_AMAZON_ASSOCIATE_TAG=your-amazon-tag
# NEXT_PUBLIC_RAKUTEN_AFFILIATE_TAG=your-rakuten-tag
