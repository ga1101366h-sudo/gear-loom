rules_version = '2';
// Firebase Console の Storage → ルール にこの内容を「全体」でコピーして使ってください。
// rules_version と service はファイルに1回だけ書きます。
service firebase.storage {
  match /b/{bucket}/o {
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /review-images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /announcements/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // カスタム手帳の画像（認証済みユーザーが書き込み可能。path の userId 一致が効かない環境向け）
    match /notebook-images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // プロフィールの所有機材画像（本人のみ書き込み、誰でも読める）
    match /owned-gear-images/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    // みんなのエフェクターボード投稿の追加画像（認証済みユーザーが本人パスにのみ書き込み、誰でも読める）
    match /board-posts/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
