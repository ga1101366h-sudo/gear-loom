rules_version = '2';
// Firebase Console の Storage → ルール にこの内容を「全体」でコピーして使ってください。
// rules_version と service はファイルに1回だけ書きます。
service firebase.storage {
  match /b/{bucket}/o {
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /review-images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /announcements/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
